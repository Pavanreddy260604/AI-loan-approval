{
  "name": "ai-loan-intelligence-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/*",
    "services/auth-service",
    "services/data-service",
    "services/gateway-service",
    "services/notification-service",
    "services/analytics-service"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:gateway": "npm run dev -w services/gateway-service",
    "dev:auth": "npm run dev -w services/auth-service",

    "dev:data": "npm run dev -w services/data-service",
    "dev:notification": "npm run dev -w services/notification-service",
    "dev:analytics": "npm run dev -w services/analytics-service",
    "install:python": "pip install -e packages/shared-python && pip install -r services/training-service/requirements.txt && pip install -r services/prediction-service/requirements.txt && pip install -r services/xai-service/requirements.txt && pip install -r services/fraud-service/requirements.txt",
    "verify:system": "node scripts/verify-system.mjs",
    "test": "npm run test -ws --if-present",
    "build": "npm run build -ws --if-present",
    "lint": "npm run lint -ws --if-present"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-abstract-transport": "^3.0.0",
    "pino-pretty": "^13.1.3",
    "pino-std-serializers": "^7.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "@aws-sdk/s3-request-presigner": "^3.1020.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  }
}
