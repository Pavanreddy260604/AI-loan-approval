# AI Loan Intelligence Platform - Environment Template
# Copy this to .env and adjust for local development.

NODE_ENV=development
CORS_ORIGIN=http://localhost:5175
PUBLIC_APP_URL=http://localhost:5175

# Database Cluster
# For local Docker, use 'postgres' as host.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
AUTH_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/auth_db
DATA_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/data_db
ANALYTICS_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/analytics_db
TRAINING_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/training_db
PREDICTION_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/prediction_db
FRAUD_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/fraud_db

# Infrastructure
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
REDIS_URL=redis://redis:6379

# MinIO / S3
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_DATASETS=loan-datasets
S3_BUCKET_MODELS=loan-models
S3_BUCKET_BATCH=batch-results

# Identity & Security
JWT_ISSUER=ai-loan-intelligence
JWT_AUDIENCE=ai-loan-platform
JWT_ACCESS_TTL_MINUTES=1440
JWT_REFRESH_TTL_DAYS=30
# RS256 Base64 Keys (Placeholders)
JWT_PRIVATE_KEY_BASE64=placeholder-replace-with-real-key
JWT_PUBLIC_KEY_BASE64=placeholder-replace-with-real-key
OTP_PEPPER=platform-default-pepper-2026-audit


# ML Integrity & Rigor
MODEL_ARTIFACT_SIGNING_KEY=audit-signing-key-2026-secret
TRAINING_RANDOM_SEED=42
XAI_KERNEL_BACKGROUND_LIMIT=50
XAI_KERNEL_NSAMPLES=200

# Service Internal URLs
AUTH_SERVICE_URL=http://auth-service:4001
DATA_SERVICE_URL=http://data-service:4003
TRAINING_SERVICE_URL=http://training-service:5007
PREDICTION_SERVICE_URL=http://prediction-service:5008
XAI_SERVICE_URL=http://xai-service:5006
FRAUD_SERVICE_URL=http://fraud-service:5004
ANALYTICS_SERVICE_URL=http://analytics-service:4006
NOTIFICATION_SERVICE_URL=http://notification-service:4005

# Mail
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=noreply@ailoan.local
